// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================
// AUTENTICAÇÃO
// ===========================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  ADMIN
  EDITOR
}

// ===========================
// BLOG
// ===========================
model BlogCategory {
  id    String     @id @default(uuid())
  slug  String     @unique
  label String
  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id          String       @id @default(uuid())
  slug        String       @unique
  title       String
  excerpt     String
  content     String       // HTML completo do artigo
  image       String       // Path da imagem
  readTime    String       // Ex: "8 min"
  featured    Boolean      @default(false)
  published   Boolean      @default(true)
  publishedAt DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
  @@index([featured])
  @@index([published])
  @@map("blog_posts")
}

// ===========================
// ACERVO (PRODUTOS)
// ===========================
model AcervoCategory {
  id       String          @id @default(uuid())
  slug     String          @unique
  label    String
  products AcervoProduct[]

  @@map("acervo_categories")
}

model AcervoFormat {
  id        String          @id @default(uuid())
  slug      String          @unique
  label     String
  icon      String          @default("BookOpen")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt
  products  AcervoProduct[]

  @@map("acervo_formats")
}

model AcervoProduct {
  id                      String         @id @default(uuid())
  slug                    String         @unique
  title                   String
  description             String
  fullContent             String?        // HTML
  image                   String
  price                   String         // Ex: "R$ 89,90"
  originalPrice           String?       // Ex: "R$ 119,90" - Preço cortado
  installmentsPrice       String?       // Ex: "12x de R$ 9,90"
  
  badge1Text              String         @default("Nova Edição 2025")
  badge1Enabled           Boolean        @default(true)
  
  badge2Text              String         @default("Oferta Especial")
  badge2Enabled           Boolean        @default(true)
  
  descriptionTitleText    String         @default("A Medicina Mudou. Sua Gestão Também Precisa Mudar.")
  descriptionTitleEnabled Boolean        @default(true)
  
  bestsellerText          String         @default("Bestseller #1 em Gestão Médica")
  readersText             String         @default("Junte-se a 2.000+ médicos leitores")
  featured                Boolean        @default(false)
  
  hotmartLink             String?
  published               Boolean        @default(true)
  order                   Int            @default(0) // Para ordenação manual
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  categoryId              String
  category                AcervoCategory @relation(fields: [categoryId], references: [id])
  formatId                String
  format                  AcervoFormat   @relation(fields: [formatId], references: [id])
  tags                    AcervoTag[]
  features                AcervoFeature[]
  benefits                AcervoBenefit[]

  @@index([slug])
  @@index([categoryId])
  @@index([formatId])
  @@index([published])
  @@map("acervo_products")
}

model AcervoTag {
  id        String        @id @default(uuid())
  name      String
  productId String
  product   AcervoProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("acervo_tags")
}

model AcervoFeature {
  id        String        @id @default(uuid())
  text      String
  productId String
  product   AcervoProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("acervo_features")
}

model AcervoBenefit {
  id        String        @id @default(uuid())
  text      String
  productId String
  product   AcervoProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("acervo_benefits")
}

// ===========================
// PALESTRAS
// ===========================
model PalestraVertente {
  id       String @id @default(uuid())
  title    String
  question String
  icon     String // Nome do ícone Lucide
  order    Int    @default(0)

  @@map("palestra_vertentes")
}

model PalestraFormato {
  id       String @id @default(uuid())
  title    String
  subtitle String // Ex: "45-60 min"
  desc     String
  order    Int    @default(0)

  @@map("palestra_formatos")
}

model PalestraEstatistica {
  id    String @id @default(uuid())
  value String // Ex: "50+"
  label String // Ex: "Eventos"
  order Int    @default(0)

  @@map("palestra_estatisticas")
}

// ===========================
// DEPOIMENTOS
// ===========================
model Depoimento {
  id        String   @id @default(uuid())
  name      String
  role      String   // Cargo
  event     String?  // Evento (opcional)
  quote     String
  image     String?
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@map("depoimentos")
}

// ===========================
// NA MÍDIA
// ===========================
model MediaFeatured {
  id          String @id @default(uuid())
  type        String // Ex: "Revista"
  outlet      String // Ex: "Harvard Business Review Brasil"
  title       String
  date        String // Ex: "Dezembro 2025"
  description String
  image       String?
  link        String

  @@map("media_featured")
}

model MediaItem {
  id     String @id @default(uuid())
  type   String // TV, Podcast, Revista, Artigo
  icon   String // Nome do ícone
  outlet String
  title  String
  date   String
  link   String
  order  Int    @default(0)

  @@map("media_items")
}

model MediaBook {
  id          String @id @default(uuid())
  title       String
  year        String
  publisher   String
  description String
  order       Int    @default(0)

  @@map("media_books")
}

model MediaPress {
  id       String @id @default(uuid())
  outlet   String
  mentions Int
  order    Int    @default(0)

  @@map("media_press")
}

// ===========================
// GALERIA
// ===========================
model GaleriaFoto {
  id    String @id @default(uuid())
  src   String
  alt   String
  title String
  order Int    @default(0)

  @@map("galeria_fotos")
}

// ===========================
// SOCIAL PROOF (HOME)
// ===========================
model SocialProofStat {
  id    String @id @default(uuid())
  value String // Ex: "200+"
  label String // Ex: "Clínicas Transformadas"
  order Int    @default(0)

  @@map("social_proof_stats")
}

// ===========================
// FORMULÁRIOS (LEADS)
// ===========================
model FormularioContato {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false) // Admin leu?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([read])
  @@map("formulario_contato")
}

model FormularioDiagnostico {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  clinic        String
  revenue       String   // Range de faturamento
  mainChallenge String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([read])
  @@map("formulario_diagnostico")
}

model FormularioMentoria {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  clinic    String
  revenue   String   // Range de faturamento
  tier      String   // Ex: "silver", "gold", "platinum"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([read])
  @@map("formulario_mentoria")
}

model FormularioConsultoria {
  id             String   @id @default(uuid())
  name           String
  email          String
  phone          String
  clinic         String
  revenue        String
  mainChallenge  String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([read])
  @@map("formulario_consultoria")
}

model FormularioPalestras {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  company   String
  eventType String?
  attendees String?
  date      String?
  message   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([read])
  @@map("formulario_palestras")
}

model FormularioNewsletter {
  id        String   @id @default(uuid())
  email     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([email])
  @@index([active])
  @@map("formulario_newsletter")
}

// ===========================
// AVALIAÇÃO/QUIZ (dados complexos)
// ===========================
model FormularioAvaliacao {
  id            String   @id @default(uuid())
  // Dados pessoais
  name          String
  email         String
  phone         String
  position      String   // Cargo
  revenue       String   // Faturamento
  employees     String   // Número de funcionários
  operationTime String   // Tempo de operação
  // Respostas do quiz (JSON ou campos separados)
  quizAnswers   Json     // Array de respostas {question, answer, score}
  totalScore    Int      // Score total calculado
  maturityLevel String   // Ex: "Nível 2: Reativo"
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([read])
  @@map("formulario_avaliacao")
}

// ===========================
// CONFIGURAÇÕES DO SITE
// ===========================
model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // Armazena JSON stringificado ou texto puro
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}
